# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# SMS Gateway
SMS_GATEWAY_API_KEY=your-sms-gateway-api-key
SMS_GATEWAY_WEBHOOK_KEY=your-sms-gateway-api-key
SMS_GATEWAY_SEND_URL=https://app.sms-gateway.app/services/send.php
SMS_GATEWAY_DEVICES=10959|1
SMS_GATEWAY_TYPE=sms
SMS_GATEWAY_PRIORITIZE=0
DEFAULT_COUNTRY_CODE=+94

# Optional production protection
ADMIN_API_KEY=choose-a-long-random-admin-key
CORS_ORIGINS=*
LOG_LEVEL=INFO
